# Секрет для подписи JWT — обязательно замените в проде
AIS_JWT_SECRET=change-me-in-production

# Ключ Anthropic API. Без него анализ работает в mock-режиме (эвристика).
AIS_ANTHROPIC_API_KEY=

# auto | claude | mock
AIS_ANALYSIS_MODE=auto

# Модель для анализа
AIS_ANTHROPIC_MODEL=claude-opus-4-8

# Batch API: один batch вместо N запросов при загрузке пачки >= порога (−50%).
# Требует Redis и claude-режим.
AIS_USE_BATCH_API=false
AIS_BATCH_THRESHOLD=5

# OCR для сканированных PDF (в docker-образ уже включены tesseract + poppler)
AIS_OCR_ENABLED=true
AIS_OCR_LANG=rus+eng

# URL БД (в docker — PostgreSQL; локально по умолчанию SQLite)
# AIS_DATABASE_URL=postgresql+asyncpg://ais:ais@localhost:5432/ai_screening

# Очередь задач (в docker — redis://redis:6379). Пусто = анализ in-process.
# AIS_REDIS_URL=redis://localhost:6379

# В проде схемой управляет Alembic. Для dev/тестов create_all включён.
# AIS_AUTO_CREATE_TABLES=true
