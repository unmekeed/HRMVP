# Секрет для подписи JWT — обязательно замените в проде
AIS_JWT_SECRET=change-me-in-production

# Ключ Anthropic API. Без него анализ работает в mock-режиме (эвристика).
AIS_ANTHROPIC_API_KEY=

# auto | claude | mock
AIS_ANALYSIS_MODE=auto

# Модель для анализа
AIS_ANTHROPIC_MODEL=claude-opus-4-8

# URL БД (по умолчанию SQLite для локальной разработки)
# AIS_DATABASE_URL=postgresql+asyncpg://ais:ais@localhost:5432/ai_screening
